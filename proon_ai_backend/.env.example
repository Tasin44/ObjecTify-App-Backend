# Proon AI Backend — Environment Variables
# Copy this to .env and fill in your actual values.
# Never commit the actual .env file to version control.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ── Database (SQLite for local dev, PostgreSQL for production) ────────────────
# DB_NAME=proon_db
# DB_USER=proon_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set CORS_ALLOW_ALL=False in production and list your exact origins below.
CORS_ALLOW_ALL=True
# CORS_ORIGINS=https://yourapp.com,https://api.yourapp.com
